import sys
def solve():
    input_data = sys.stdin.read().splitlines()
    if not input_data:
        return
    
    T = int(input_data[0])
    for i in range(1, T + 1):
        s = input_data[i]
        digit_sum = 0
        for char in s:
            if '0' <= char <= '9':
                digit_sum += int(char)
        print(digit_sum)

if __name__ == '__main__':
    solve()
