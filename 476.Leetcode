int findComplement(int num) {
    int i=0;
    int a[32],k;
    if(num==0) return 1;
    for(k=0;k<32;k++){
        a[k]=-1;
    }
    while(num>0){
        int rem=num%2;
        a[i++]=(rem==0)?1:0;
        num=num/2;
    }
    int sum=0,j=0;
    for(i=0;i<32;i++){
        if(a[i]!=-1){
            sum+=a[i]*(int)pow(2,j);
            j++;
        }
    }
    return sum;

    
}
